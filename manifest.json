{
  "manifest_version": 3,
  "name": "Meet Sidekick",
  "version": "0.2.0",
  "description": "Real-time interview assistant — listens to your meeting and suggests answers based on your experience.",
  "permissions": [
    "activeTab",
    "tabCapture",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://resume-forge-rho.vercel.app/*",
    "https://cdn.jsdelivr.net/*",
    "https://huggingface.co/*",
    "https://cdn-lfs.huggingface.co/*",
    "https://cdn-lfs-us-1.huggingface.co/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Meet Sidekick"
  },
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
