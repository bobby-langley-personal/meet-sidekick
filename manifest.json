{
  "manifest_version": 3,
  "name": "Meet Sidekick",
  "version": "0.1.0",
  "description": "Real-time interview assistant — listens in during meetings and suggests answers based on your experience.",
  "permissions": [
    "activeTab",
    "tabCapture",
    "storage",
    "sidePanel"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Meet Sidekick"
  },
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
